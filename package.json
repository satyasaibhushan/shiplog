{
  "name": "shiplog",
  "version": "0.1.0",
  "description": "Visualize and summarize your GitHub contributions locally",
  "type": "module",
  "bin": {
    "shiplog": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outdir dist --target bun && bun build src/web/main.tsx --outdir dist/web --minify",
    "build:css": "bunx @tailwindcss/cli -i src/web/styles/globals.css -o dist/web/styles.css --minify",
    "start": "bun run src/cli/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "check": "bun run lint && bun run build"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "lucide-react": "^1.8.0",
    "open": "^11.0.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark": "^15.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
